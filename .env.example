APP_NAME=coachos-auth-service
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/coachos_auth
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO
INTERNAL_SERVICE_TOKENS={"athlete-service":"replace-with-athlete-service-token"}
ATHLETE_INVITATION_EXPIRATION_HOURS=48
ATHLETE_INVITATION_BASE_URL=http://localhost:5173/invitations/accept
ALLOW_DEV_INVITATION_URL_RESPONSE=true
MAX_INVITATION_RESENDS_PER_HOUR=3
ATHLETE_SERVICE_INTERNAL_URL=http://localhost:8002
INTERNAL_SERVICE_NAME=auth-service
INTERNAL_SERVICE_TOKEN=replace-with-auth-service-token
UPSTREAM_TIMEOUT_SECONDS=5
